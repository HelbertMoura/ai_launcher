# ==============================================================================
# AI Launcher Pro - Environment Variables (exemplo público)
# ==============================================================================
# Copie este arquivo para `.env.local` (ignorado pelo git) e preencha os valores.
# Só valores com prefixo VITE_ ou TAURI_ são expostos ao frontend (vide vite.config.ts).

# Ativa o Painel Admin (aba extra com CRUD de providers, etc.).
# Público/usuários normais NÃO devem setar. Deixe vazio ou ausente.
# VITE_ADMIN_MODE=1

# (Opcional) Pré-popula a chave da Z.AI no primeiro boot do modo admin.
# Se vazio, você cadastra manualmente pela UI do painel.
# VITE_ZAI_API_KEY=

# (Opcional) Pré-popula a chave da MiniMax (reservado pra uso futuro).
# VITE_MINIMAX_API_KEY=
