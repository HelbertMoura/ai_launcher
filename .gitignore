target/
**/target/
src-tauri/WixTools/
src-tauri/gen/schemas/

# Tauri generated (keep icons top-level, drop platform-specific android/ios)
src-tauri/icons/android/
src-tauri/icons/ios/

# --- Certs / Signing (NUNCA commitar) ---
scripts/certs/
*.pfx
*.p12
*.key
*.pem
*.crt
*.cer

# --- Env / Secrets ---
.env
.env.*
!.env.example

# --- Logs / Debug ---
*.log
tea_debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Sistema operacional ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editores / IDEs ---
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.history/

# --- Temp / Cache ---
.cache/
coverage/
*.tmp
*.temp

# --- Build artifacts extras ---
*.msi
*.nsis
*.dmg
*.app

# --- Claude Code local settings (per-dev, never commit) ---
.claude/
.superpowers/
AGENTS.md
CLAUDE.md

